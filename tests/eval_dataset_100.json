  "agent_mapping": {
    "1": "event_collection",
    "2": "itinerary_planning",
    "3": "preference",
    "4": "memory_query",
    "5": "rag_knowledge",
    "6": "information_query"
  },
  "rag_cluster_mapping": {
    "1": "国内差旅制度类",
    "2": "报销材料与系统流程类",
    "3": "会议费制度类",
    "4": "因公出国/出境类",
    "5": "合规禁止事项类",
    "6": "异常与辅助出行类"
  },
  "evaluation_notes": {
    "intent_success_rule": "gold.required_agents 全部出现在 predicted agent_schedule 中即算意图识别成功，额外多调度不扣分。",
    "preference_rule": "gold.preference.eval=true 的样本只判断是否触发偏好行为。",
    "rag_rule": "gold.rag.eval=true 的样本调用系统真实混合检索 Top-K，再判断检索 chunk 与 gold_evidence 的语义相似度是否达到 similarity_threshold；gold_cluster 支持单值或数组，数组按 OR 判断。",
    "cache_rule": "缓存命中率由运行时统计 Redis short_term/preferences/summary 的 hit/miss，不需要人工真值。",
    "rag_gold_source": "当前 gold_evidence 已由 tests/rag_evidence_review.json 的 review_search_query 覆写，similarity_threshold=0.70。"
  },
